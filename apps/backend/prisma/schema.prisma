generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parents  Parent[]
  children Child[]
}

model Parent {
  id        String     @id @default(uuid())
  familyId  String
  family    Family     @relation(fields: [familyId], references: [id])
  phone     String     @unique
  nickname  String
  role      ParentRole @default(PRIMARY)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  approvals LearningPushApproval[]
  notifications NotificationLog[]

  @@index([familyId])
}

model Child {
  id        String   @id @default(uuid())
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  name      String
  gender    Gender
  birthDate DateTime
  grade     Int
  k12Stage  K12Stage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile ChildProfile?
  pushes   LearningPush[]
  sessions LearningSession[]
  wordProgresses WordProgress[]
  gameProfile GameProfile?
  notifications NotificationLog[]
  settings ChildLearningSettings[]

  @@index([familyId])
}

model ChildLearningSettings {
  id                 String   @id @default(uuid())
  childId             String
  child               Child    @relation(fields: [childId], references: [id])
  subject             Subject
  autoApprove         Boolean  @default(false)
  weekdayTimeWindows  Json?
  weekendTimeWindows  Json?
  dailyDurationMin    Int      @default(20)
  wordsPerSession     Int      @default(10)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([childId, subject])
  @@index([childId])
}

model ChildProfile {
  id           String   @id @default(uuid())
  childId       String   @unique
  child         Child    @relation(fields: [childId], references: [id])
  learningStyle Json?
  attentionSpan Int?
  interests     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LearningPush {
  id              String     @id @default(uuid())
  childId          String
  child            Child      @relation(fields: [childId], references: [id])
  subject          Subject
  type             LearningType
  summary          String
  reason           String
  expectedOutcome  String
  content          Json
  scheduledAt      DateTime
  status           PushStatus @default(PENDING_APPROVAL)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  approval         LearningPushApproval?

  @@index([childId, status])
  @@index([scheduledAt])
}

model ParentApprovalWorkflowRun {
  id             String                          @id @default(uuid())
  runId          String                          @unique
  workflowId     String
  familyId       String
  childId        String
  pushId         String                          @unique
  status         ParentApprovalWorkflowRunStatus @default(RUNNING)
  suspendPayload Json?
  resumeLabels   Json?
  lastError      String?
  startedAt      DateTime
  suspendedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt

  @@index([familyId, status])
  @@index([pushId, status])
}

model LearningPushApproval {
  id              String         @id @default(uuid())
  pushId           String         @unique
  push             LearningPush   @relation(fields: [pushId], references: [id])
  parentId         String
  parent           Parent         @relation(fields: [parentId], references: [id])
  action           ApprovalAction
  comment          String?
  modifiedContent  Json?
  createdAt        DateTime       @default(now())
}

model LearningSession {
  id           String                @id @default(uuid())
  childId       String
  child         Child                 @relation(fields: [childId], references: [id])
  type          LearningType
  status        LearningSessionStatus @default(IN_PROGRESS)
  payload       Json?
  answerLogs    Json?
  accuracy      Float?
  durationSec   Int?
  startedAt     DateTime              @default(now())
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  briefing      LearningBriefing?

  @@index([childId, type])
  @@index([childId, createdAt])
}

model Word {
  id         String   @id @default(uuid())
  value      String   @unique
  phonetic   String?
  meaning    String?
  difficulty Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  progresses WordProgress[]
}

model WordProgress {
  id             String        @id @default(uuid())
  childId         String
  child           Child         @relation(fields: [childId], references: [id])
  wordId          String
  word            Word          @relation(fields: [wordId], references: [id])
  stage           EbReviewStage @default(NEW)
  nextReviewAt    DateTime?
  reviewCount     Int           @default(0)
  correctCount    Int           @default(0)
  incorrectCount  Int           @default(0)
  mastered        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([childId, wordId])
  @@index([childId, stage])
  @@index([nextReviewAt])
}

model LearningBriefing {
  id               String   @id @default(uuid())
  learningSessionId String   @unique
  learningSession   LearningSession @relation(fields: [learningSessionId], references: [id])
  childId           String
  headline          String
  accuracy          Float?
  summary           String
  strengths         Json?
  weaknesses        Json?
  advice            String?
  createdAt         DateTime @default(now())

  @@index([childId, createdAt])
}

model GameProfile {
  id          String   @id @default(uuid())
  childId      String   @unique
  child        Child    @relation(fields: [childId], references: [id])
  points       Int      @default(0)
  level        Int      @default(1)
  streakDays   Int      @default(0)
  lastStudyDate DateTime?
  updatedAt    DateTime @updatedAt

  pointLogs PointLog[]
}

model PointLog {
  id          String   @id @default(uuid())
  gameProfileId String
  gameProfile   GameProfile @relation(fields: [gameProfileId], references: [id])
  delta       Int
  reason      String
  createdAt   DateTime @default(now())

  @@index([gameProfileId, createdAt])
}

model NotificationLog {
  id          String             @id @default(uuid())
  parentId     String?
  parent       Parent?            @relation(fields: [parentId], references: [id])
  childId      String?
  child        Child?             @relation(fields: [childId], references: [id])
  familyId     String
  type         NotificationType
  channel      NotificationChannel @default(IN_APP)
  title        String
  content      String
  payload      Json?
  createdAt    DateTime           @default(now())

  @@index([parentId, createdAt])
  @@index([familyId, createdAt])
  @@index([childId, createdAt])
}

enum ParentRole {
  PRIMARY
  SECONDARY
}

enum Gender {
  MALE
  FEMALE
}

enum K12Stage {
  LOWER_PRIMARY
  MIDDLE_PRIMARY
  UPPER_PRIMARY
  JUNIOR_HIGH
}

enum Subject {
  ENGLISH
}

enum LearningType {
  WORD_LEARNING
  WORD_REVIEW
  PRONUNCIATION
  SENTENCE_BUILDING
  READING
  ORAL_DIALOGUE
}

enum PushStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  MODIFIED
  POSTPONED
  DELIVERED
  COMPLETED
  EXPIRED
}

enum ApprovalAction {
  APPROVE
  REJECT
  MODIFY
  POSTPONE
}

enum ParentApprovalWorkflowRunStatus {
  RUNNING
  SUSPENDED
  SUCCESS
  FAILED
  TRIPWIRE
  CANCELED
}

enum LearningSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
}

enum EbReviewStage {
  NEW
  REVIEW_5MIN
  REVIEW_30MIN
  REVIEW_12H
  REVIEW_1D
  REVIEW_2D
  REVIEW_4D
  REVIEW_7D
  REVIEW_15D
  MASTERED
}

enum NotificationType {
  PUSH_PENDING
  PUSH_APPROVED
  PUSH_REJECTED
  LEARNING_BRIEFING_READY
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  WECHAT_SUBSCRIBE
}
