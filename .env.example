# Infrastructure
POSTGRES_DB=ai_companion
POSTGRES_USER=ai_companion
POSTGRES_PASSWORD=ai_companion_dev
POSTGRES_PORT=5432
REDIS_PORT=6379

# Backend
BACKEND_PORT=3000
DATABASE_URL=postgresql://ai_companion:ai_companion_dev@localhost:5432/ai_companion
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_me_in_production
JWT_EXPIRES_IN=7d

# AI
AI_PROVIDER=mock
# Supported values:
# - mock
# - openai
# - litellm
# - openai_compatible
AI_MODEL=gpt-4o-mini
AI_BASE_URL=
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# LiteLLM (OpenAI-compatible)
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_MODEL=gpt-4o-mini

# Generic OpenAI-compatible providers (vLLM/OneAPI/Groq-compatible gateways, etc.)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Speech Evaluation
SPEECH_EVAL_PROVIDER=mock
XUNFEI_EVAL_ENDPOINT=

# Push Lifecycle
PUSH_EXPIRE_HOURS=48

# Mastra Workflow Storage
MASTRA_PG_SCHEMA=mastra
# Set true in pre-prod/prod to enforce durable snapshot-only resume path
MASTRA_DURABLE_REQUIRED=false

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
